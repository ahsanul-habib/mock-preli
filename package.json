{
  "name": "ticket-triage",
  "version": "1.0.0",
  "private": true,
  "description": "Rules-based CRM ticket triage service (Node.js + Express + TypeScript).",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
